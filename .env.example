# Copie de référence — les vraies valeurs se configurent dans le dashboard Vercel
# (Settings > Environment Variables). Ne mets JAMAIS de vraie valeur dans ce fichier.

# Token du bot donné par @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé API Fish Audio (https://fish.audio -> API keys)
FISH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret inventé par toi (lettres/chiffres, 1 à 256 caractères).
# Il doit être IDENTIQUE dans la commande setWebhook (voir README).
TELEGRAM_WEBHOOK_SECRET=un-long-secret-aleatoire

# Fournis automatiquement par l'intégration Upstash Redis du Marketplace Vercel
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxx

# --- Enrichissement automatique des émotions (OPTIONNEL, un seul suffit) ---

# Option 1 (GRATUIT, recommandé) : clé Google Gemini (aistudio.google.com/apikey)
GEMINI_API_KEY=AIzaxxxxxxxxxxxx

# Option 2 (GRATUIT) : clé Groq (console.groq.com/keys)
GROQ_API_KEY=gsk_xxxxxxxxxxxx

# Option 3 (payant) : clé Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Priorité : Gemini > Groq > Claude.
# Si aucune clé : les textes partent tels quels chez Fish Audio.
